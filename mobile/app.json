{
  "expo": {
    "name": "MonDevisMinute",
    "slug": "mondevisminute-mobile",
    "owner": "fethi.ameur",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mondevisminute",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mondevisminute.mobile"
    },
    "android": {
      "package": "com.mondevisminute.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "mondevisminute.com",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "mondevisminute.com",
              "pathPrefix": "/verify-email"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "MonDevisMinute utilise le microphone pour la dictée vocale de vos devis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MonDevisMinute accède à vos photos pour ajouter le logo de votre entreprise.",
          "cameraPermission": "MonDevisMinute utilise l'appareil photo pour scanner le logo ou ajouter une photo de chantier."
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://batipro-backend.onrender.com/api",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "20f870cb-f29c-44ce-a36e-aa8ef8496c4c"
      }
    }
  }
}
