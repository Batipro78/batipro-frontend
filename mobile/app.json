{
  "expo": {
    "name": "BatiPro",
    "slug": "batipro-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "batipro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.batipro.mobile"
    },
    "android": {
      "package": "com.batipro.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://batipro-backend.onrender.com/api",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6886c377-4d2e-41a0-992f-69820954675e"
      }
    }
  }
}
